# Firebase admin account (used by the server to write to Firestore)
ADMIN_EMAIL="admin-proassess@system.com"
ADMIN_PASSWORD="choose-a-strong-password"

# Gemini AI
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL (used in invite email links)
APP_URL="http://localhost:3000"

# SMTP – configure any SMTP provider (Gmail, Resend, SendGrid, etc.)
# If left blank, invite links still work but emails won't be sent.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="ProAssess <you@gmail.com>"
